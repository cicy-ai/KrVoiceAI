# KrVoice GPU 镜像:CosyVoice2 声音克隆 + LatentSync 512 唇形同步 + 编排全链
# 固化 2026-07-04 Colab 实战踩平的所有坑:
#   - torch 钉 2.5.1(torchaudio 2.9 torchcodec 路由与 CosyVoice 不兼容;LatentSync 同版)→ 直接用官方 2.5.1 基镜像
#   - onnxruntime 用 CPU 1.18.1(gpu 新版要 libcudart.so.13/CUDA13)
#   - mediapipe/decord/insightface 去钉版(老钉版无新 py wheel)
#   - accelerate>=0.34(peft clear_device_cache)
#   - CosyVoice requirements 装不全 → 无条件补装关键依赖清单
# 权重不打进镜像(~5GB),运行时外挂卷: -v krvoice-models:/models(entrypoint 自动下载一次)
# 用法:
#   docker run --gpus all -v krvoice-models:/models -v $PWD/data:/data \
#     cicybot/krvoice-gpu bash /opt/KrVoiceAI/colab/produce.sh /data/driver.mp4 "文案" ecommerce /data/voice.m4a /data/assets

FROM pytorch/pytorch:2.5.1-cuda12.1-cudnn9-runtime

ENV DEBIAN_FRONTEND=noninteractive PIP_NO_CACHE_DIR=1 \
    WORKDIR=/opt PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
RUN apt-get update && apt-get install -y --no-install-recommends \
        git ffmpeg libgl1 libglib2.0-0 wget bc fonts-noto-cjk build-essential \
    && rm -rf /var/lib/apt/lists/*   # build-essential: pyworld 等无 wheel 包要 g++ 源码编译

WORKDIR /opt

# ---- LatentSync(踩坑修复 + 去 torch 钉版保住基镜像 2.5.1) ----
RUN git clone --depth 1 https://github.com/bytedance/LatentSync.git && cd LatentSync && \
    sed -i 's/^mediapipe==.*/mediapipe/'            requirements.txt && \
    sed -i 's/^decord==.*/eva-decord/'              requirements.txt && \
    sed -i 's/^insightface==.*/insightface/'        requirements.txt && \
    sed -i '/^onnxruntime/d;/^torch==/d;/^torchvision==/d;/^torchaudio==/d' requirements.txt && \
    pip install -r requirements.txt && \
    pip install edge-tts "accelerate>=0.34" "huggingface_hub[cli]" && \
    touch .deps_done

# ---- CosyVoice2(requirements 尽力装 + 无条件补装今天验证过的清单) ----
RUN git clone --depth 1 --recursive https://github.com/FunAudioLLM/CosyVoice.git && cd CosyVoice && \
    sed -i '/^torch==/d;/^torchvision==/d;/^torchaudio==/d;/^onnxruntime/d;/^deepspeed/d' requirements.txt && \
    (pip install -r requirements.txt || true) && \
    pip install modelscope openai-whisper \
        hyperpyyaml hydra-core hydra-colorlog omegaconf rootutils rich einops inflect unidecode \
        conformer diffusers lightning wget pyworld soundfile matplotlib gdown pydub wetext && \
    touch .cv_deps_done

# ---- onnxruntime 统一 CPU 1.18.1(最后装,防被前面覆盖;只做分词/人脸检测,CPU 够) ----
RUN pip uninstall -y onnxruntime-gpu onnxruntime 2>/dev/null; pip install "onnxruntime==1.18.1"

# ---- 编排层依赖 + 项目脚本 ----
RUN pip install faster-whisper pyyaml httpx
COPY colab/  /opt/KrVoiceAI/colab/
COPY config/ /opt/KrVoiceAI/config/
COPY docker/entrypoint-gpu.sh /opt/entrypoint.sh
RUN chmod +x /opt/entrypoint.sh /opt/KrVoiceAI/colab/*.sh

# 构建期校验两大模型能 import(缺包当场暴露,不留到运行时)
RUN cd /opt/CosyVoice && python -c "import sys; sys.path.append('third_party/Matcha-TTS'); from cosyvoice.cli.cosyvoice import CosyVoice2; print('CosyVoice import OK')"
RUN cd /opt/LatentSync && python -c "from scripts import inference; print('LatentSync import OK')" || \
    echo "LatentSync import 跳过(部分依赖运行时才就绪)"

ENTRYPOINT ["/opt/entrypoint.sh"]
CMD ["bash"]
